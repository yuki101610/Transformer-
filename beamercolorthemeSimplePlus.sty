% -----------------------------------------------------------
% ブロックカラーの再定義（Nordic Style）
% -----------------------------------------------------------

% 1. Standard Block (Blue系): 落ち着いたスレートブルー
\definecolor{NordicBlueTitle}{rgb}{0.23, 0.30, 0.45} % タイトル背景（濃い）
\definecolor{NordicBlueBody} {rgb}{0.93, 0.94, 0.96} % 本文背景（極薄い）

\setbeamercolor{block title}{fg=white, bg=NordicBlueTitle}
\setbeamercolor{block body} {fg=black, bg=NordicBlueBody}

% 2. Alert Block (Red系): 攻撃的でないブリックレッド
\definecolor{NordicRedTitle}{rgb}{0.80, 0.40, 0.40} % タイトル背景（濃い）
\definecolor{NordicRedBody} {rgb}{0.98, 0.92, 0.92} % 本文背景（極薄い）

\setbeamercolor{block title alerted}{fg=white, bg=NordicRedTitle}
\setbeamercolor{block body alerted} {fg=black, bg=NordicRedBody}

% 3. Example Block (Green系): 知的なティールグリーン
\definecolor{NordicGreenTitle}{rgb}{0.25, 0.55, 0.50} % タイトル背景（濃い）
\definecolor{NordicGreenBody} {rgb}{0.92, 0.96, 0.94} % 本文背景（極薄い）

\setbeamercolor{block title example}{fg=white, bg=NordicGreenTitle}
\setbeamercolor{block body example} {fg=black, bg=NordicGreenBody}

